Algoritmo "H7_Volume_de_uma_caixa_retangular"
// Disciplina   : [Lógica de Programaçăo em VisualG]
// Professor    : Jailson Costa
// Descriçăo    : Calcular o volume de uma caixa retangular.
// Autor(a)     : Artur Queiroz
// Data atual   : 21/04/2026
Var
// Seçăo de Declaraçőes das variáveis
comprimento, largura, altura, volume : real

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc...
escreva("Digite o comprimento da caixa: ")
leia(comprimento)

escreva("Digite a largura da caixa: ")
leia(largura)

escreva("Digite a altura da caixa: ")
leia(altura)

volume <- comprimento * largura * altura

escreval("O volume da caixa e: ", volume:0:2)

Fimalgoritmo