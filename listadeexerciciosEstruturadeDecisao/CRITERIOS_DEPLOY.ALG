Algoritmo "criterios_deploy"
// Disciplina   : [Lógica de Programaçăo em VisualG]
// Professor    : Jailson Costa
// Descriçăo    : Ler a cobertura de testes e se o gestor aprovou,
//                para decidir se o deploy sera autorizado
// Autor(a)     : Artur Queiroz
// Data atual   : 21/04/2026

Var
// Seçăo de Declaraçőes das variáveis
   cobertura : real
   gestor_aprovou : logico

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   escreva("Digite a porcentagem de cobertura de testes: ")
   leia(cobertura)

   escreva("O gestor aprovou? ")
   leia(gestor_aprovou)

   se cobertura > 80 ou gestor_aprovou entao
      escreval("Deploy Autorizado")
   senao
      escreval("Deploy Nao Autorizado")
   fimse

Fimalgoritmo