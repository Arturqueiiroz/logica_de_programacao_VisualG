Algoritmo "calculo_imc"
// Disciplina   : [Lógica de Programaçăo em VisualG]
// Professor    : Jailson Costa
// Descriçăo    : Ler o peso e a altura, calcular o IMC e classificar
//                o resultado
// Autor(a)     : Artur Queiroz
// Data atual   : 21/04/2026

Var
// Seçăo de Declaraçőes das variáveis
   peso, altura, imc : real

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   escreva("Digite o peso: ")
   leia(peso)

   escreva("Digite a altura: ")
   leia(altura)

   imc <- peso / (altura * altura)

   escreval("IMC: ", imc:0:2)

   se imc < 18.5 entao
      escreval("Abaixo do peso")
   senao
      se imc < 25 entao
         escreval("Normal")
      senao
         se imc < 30 entao
            escreval("Sobrepeso")
         senao
            escreval("Obesidade")
         fimse
      fimse
   fimse

Fimalgoritmo