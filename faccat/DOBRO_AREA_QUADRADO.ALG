Algoritmo "dobro_area_quadrado"
// Disciplina   : [Lógica de Programaçăo em VisualG]
// Professor    : Jaison Costa
// Descriçăo    : Calcular a area de um quadrado e mostrar o dobro dessa area
// Autor(a)     : Artur Queiroz
// Data atual   : 19/04/2026

Var
// Seçăo de Declaraçőes das variáveis
lado, area, dobro_area : real
Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc...
escreva("Digite o lado do quadrado: ")
leia(lado)
area <- lado * lado
dobro_area <- area * 2
escreval("A area do quadrado e: ", area)
escreval("O dobro da area e: ", dobro_area)

Fimalgoritmo