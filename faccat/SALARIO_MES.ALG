Algoritmo "salario_mes"
// Disciplina   : [Lógica de Programaçăo em VisualG]
// Professor    : Jaison Costa
// Descriçăo    : Calcular o salario total do mes com base no valor por hora e horas trabalhadas
// Autor(a)     : Artur Queiroz
// Data atual   : 19/04/2026

Var
// Seçăo de Declaraçőes das variáveis
salario_hora, salario_total : real
horas_trabalhadas : inteiro
Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc...
escreva("Digite quanto voce ganha por hora: ")
leia(salario_hora)
escreva("Digite o numero de horas trabalhadas no mes: ")
leia(horas_trabalhadas)
salario_total <- salario_hora * horas_trabalhadas
escreval("O salario total do mes e: ", salario_total)

Fimalgoritmo