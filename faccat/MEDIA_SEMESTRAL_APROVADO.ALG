Algoritmo "media_semestral_aprovado"
// Disciplina   : [Lógica de Programaçăo em VisualG]
// Professor    : Jailson Costa
// Descriçăo    : Ler duas notas, calcular a media semestral e informar se o aluno foi aprovado
// Autor(a)     : Artur Queoz
// Data atual   : 20/04/2026

Var
// Seçăo de Declaraçőes das variáveis
nota1, nota2, media : real

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc...
escreva("Digite a primeira nota: ")
leia(nota1)

escreva("Digite a segunda nota: ")
leia(nota2)

media <- (nota1 + nota2) / 2

escreval("A media semestral e: ", media)

se media >= 6 entao
   escreval("PARABENS! Voce foi aprovado!")
fimse

Fimalgoritmo