Algoritmo "login_usuario"
// Disciplina   : [Lógica de Programaçăo em VisualG]
// Professor    : Jailson Costa
// Descriçăo    : Verificar codigo de usuario e senha
// Autor(a)     : Artur Queiroz
// Data atual   : 20/04/2026

Var
// Seçăo de Declaraçőes das variáveis
codigo_usuario, senha : inteiro

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc...
escreva("Digite o codigo do usuario: ")
leia(codigo_usuario)

se codigo_usuario <> 1234 entao
   escreval("Usuario invalido!")
senao
   escreva("Digite a senha: ")
   leia(senha)

   se senha <> 9999 entao
      escreval("Senha incorreta")
   senao
      escreval("Acesso permitido")
   fimse
fimse

Fimalgoritmo